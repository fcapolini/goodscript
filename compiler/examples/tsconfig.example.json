{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "goodscript": {
    "level": "clean"
  },
  "include": ["src/**/*.gs.ts", "src/**/*.gs.tsx"],
  "exclude": ["node_modules", "dist"]
}
